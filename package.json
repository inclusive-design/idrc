{
  "name": "@inclusive-design/idrc",
  "description": "Website for the Inclusive Design Research Centre.",
  "main": "eleventy.config.js",
  "type": "module",
  "scripts": {
    "build": "npm-run-all -l clean build:eleventy",
    "build:eleventy": "cross-env NODE_ENV=production eleventy",
    "clean": "rimraf _site",
    "debug": "cross-env DEBUG=Eleventy* eleventy",
    "dev": "cross-env NODE_ENV=development eleventy --serve",
    "lint": "run-s -l lint:*",
    "lint:stylelint": "stylelint \"**/*.css\"",
    "lint:eslint": "eslint",
    "lint:markdownlint": "markdownlint-cli2 \"**/*.md\"",
    "test": "echo \"No test specified\" && exit 0",
    "start": "npm-run-all -l clean dev",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/inclusive-design/idrc.git"
  },
  "keywords": [
    "inclusive-design"
  ],
  "author": "OCAD University <idrc@ocadu.ca>",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/inclusive-design/idrc/issues"
  },
  "homepage": "https://github.com/inclusive-design/idrc#readme",
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "6.0.0",
    "@11ty/eleventy-navigation": "^1.0.0",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "d3-selection": "^3.0.0",
    "eleventy-plugin-fluid": "^3.0.0",
    "infusion": "^4.8.0",
    "markdown-it": "^14.0.0",
    "npm-run-all2": "^8.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@inclusive-design/eslint-config": "^0.4.0",
    "@inclusive-design/markdownlint-config": "^0.1.0",
    "@inclusive-design/stylelint-config": "^0.1.0",
    "cross-env": "^10.0.0",
    "eslint": "^10.0.0",
    "husky": "^9.0.0",
    "linkedom": "^0.18.0",
    "lint-staged": "^16.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^6.0.0"
  },
  "lint-staged": {
    "*.css": [
      "stylelint --fix"
    ],
    "*.{cjs,js,json,mjs}": [
      "eslint --fix"
    ],
    "*.md": [
      "eslint --fix",
      "markdownlint-cli2 --fix"
    ]
  },
  "version": "2026.5.0"
}
